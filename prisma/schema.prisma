generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                     String   @id @default(uuid())
  createdAt              DateTime @default(now()) @map("created_at")
  type                   String
  nombre                 String
  apellido               String
  email                  String
  whatsapp               String
  cantidadPropiedades    String?  @map("cantidad_propiedades")
  arrendadas             String?  @map("arrendadas")
  adminHoum              String?  @map("admin_houm")
  marketingAttribution   Json?    @map("marketing_attribution")

  @@map("leads")
}
