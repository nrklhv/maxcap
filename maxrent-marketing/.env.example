# =============================================================================
# MaxRent Marketing — Variables de entorno
# =============================================================================
# Copiar como .env.local y completar.
# =============================================================================

# --- Base ---
# URL pública del subdominio. En local: http://localhost:3003
NEXTAUTH_URL=http://localhost:3003
# Generar con: openssl rand -base64 32 (obligatorio en producción)
NEXTAUTH_SECRET=

# --- Acceso ---
# Super-admins (CSV). Estos correos siempre pueden entrar Y acceden a /admin
# para gestionar la lista. NO se almacenan en BD para evitar bootstrap problem.
# Ejemplo: MARKETING_SUPER_ADMINS=nk@houm.com
MARKETING_SUPER_ADMINS=

# Fallback opcional para dev local sin BD: lista de correos autorizados
# adicionales (CSV). En producción la lista vive en la tabla `marketing_access`
# de la Neon del portal y se gestiona desde /admin.
MARKETING_ALLOWED_EMAILS=

# --- Base de datos (compartida con el portal) ---
# Esta app usa la misma Neon que el portal — sólo lee/escribe la tabla
# `marketing_access` (allowlist de correos). Las migraciones viven en el portal
# y corren automáticamente en sus deploys.
# En Vercel: copiar el DATABASE_URL desde el proyecto del portal.
DATABASE_URL=

# --- Google OAuth ---
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client ID → Web Application
# Authorized redirect URIs:
#   http://localhost:3003/api/auth/callback/google
#   https://marketing.maxrent.cl/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
