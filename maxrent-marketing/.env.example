# =============================================================================
# MaxRent Marketing — Variables de entorno
# =============================================================================
# Copiar como .env.local y completar.
# =============================================================================

# --- Base ---
# URL pública del subdominio. En local: http://localhost:3003
NEXTAUTH_URL=http://localhost:3003
# Generar con: openssl rand -base64 32 (obligatorio en producción)
NEXTAUTH_SECRET=

# --- Allowlist de acceso ---
# Lista de emails (separados por coma o espacio) autorizados a entrar.
# Si está vacía o no definida, NADIE puede entrar (cerrado por defecto).
# Ejemplo: MARKETING_ALLOWED_EMAILS=nk@houm.com,rodrigo@maxrent.cl,chama@houm.com
MARKETING_ALLOWED_EMAILS=

# --- Google OAuth ---
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client ID → Web Application
# Authorized redirect URIs:
#   http://localhost:3003/api/auth/callback/google
#   https://marketing.maxrent.cl/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
