{
  "name": "maxrent-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:metadata-merge": "tsx scripts/verify-metadata-merge.ts",
    "db:generate": "prisma generate",
    "db:push": "node scripts/prisma-with-merged-env.cjs db push",
    "db:push:force": "node scripts/prisma-with-merged-env.cjs db push --accept-data-loss",
    "db:migrate": "node scripts/prisma-with-merged-env.cjs migrate dev",
    "db:studio": "node scripts/prisma-with-merged-env.cjs studio",
    "db:seed": "node scripts/tsx-with-merged-env.cjs prisma/seed.ts",
    "debug:db": "node scripts/debug-local-env.cjs",
    "env:align-db": "node scripts/align-database-url.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/client": "^6.1.0",
    "@vercel/analytics": "^2.0.1",
    "csv-parse": "^5.6.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.21",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
