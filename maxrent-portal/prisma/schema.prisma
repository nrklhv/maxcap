// =============================================================================
// MaxRent Portal — Prisma Schema
// =============================================================================
// Modelos compatibles con NextAuth.js v5 + portal de clientes
// Ref: https://authjs.dev/getting-started/adapters/prisma
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// AUTH — Modelos requeridos por NextAuth.js (Prisma Adapter)
// =============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Portal inversionista (misma cuenta puede ser broker y staff)
  canInvest Boolean @default(true)

  /// Acceso interno MaxRent (solo /staff/*); no se auto-asigna en registro público
  staffRole StaffRole @default(NONE)

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Portal relations
  profile           Profile?
  creditEvaluations CreditEvaluation[]
  reservations      Reservation[]

  // Relación con leads existentes (opcional, para vincular)
  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id])

  /// null = nunca solicitó ser broker; PENDING/APPROVED/REJECTED
  brokerAccessStatus BrokerAccessStatus?
  brokerReviewedAt   DateTime?

  brokerProfile BrokerProfile?

  /// Broker aprobado al que este inversionista queda asociado (staff o flujo de invitación).
  sponsorBrokerUserId                String?
  sponsorBrokerAssignedAt            DateTime?
  sponsorBrokerAssignedByStaffUserId String?

  sponsorBroker      User?  @relation("BrokerSponsorship", fields: [sponsorBrokerUserId], references: [id], onDelete: SetNull)
  sponsoredInvestors User[] @relation("BrokerSponsorship")

  /// Invites sent by this user when they act as an approved broker.
  brokerInvestorInvitesSent BrokerInvestorInvite[] @relation("BrokerInvestorInviteBroker")
  /// Invites consumed when this user registered / claimed as investor.
  brokerInvestorInvitesConsumed BrokerInvestorInvite[] @relation("BrokerInvestorInviteRegistered")

  @@index([sponsorBrokerUserId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// PORTAL — Modelos del negocio
// =============================================================================

model Profile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  firstName            String?
  lastName             String?
  contactEmail         String?  @unique // Email de contacto (no es el email de login NextAuth)
  rut                  String?  @unique
  phone                String?
  address              String?
  commune              String?  // Comuna
  city                 String?
  onboardingCompleted  Boolean  @default(false)
  additionalData       Json?    // Datos extra que se vayan necesitando
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// Datos comerciales para postulación al canal broker (separado del Profile inversionista).
model BrokerProfile {
  userId        String  @id
  companyName   String
  jobTitle      String
  isIndependent Boolean @default(false)
  websiteUrl    String?
  linkedinUrl   String?
  pitch         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("broker_profiles")
}

model CreditEvaluation {
  id               String              @id @default(cuid())
  userId           String
  status           EvaluationStatus    @default(PENDING)
  score            Int?
  riskLevel        RiskLevel?
  maxApprovedAmount Decimal?           @db.Decimal(12, 2)
  summary          String?             @db.Text
  rawResponse      Json?               // Respuesta completa de Floid
  errorMessage     String?             // Si falló, por qué
  requestedAt      DateTime            @default(now())
  completedAt      DateTime?
  /// Consentimiento explícito del inversionista antes de llamar a Floid
  consentAt        DateTime?
  consentVersion   String?
  /// Identificador de caso devuelto por Floid (útil en flujos asíncronos / auditoría)
  floidCaseId      String?
  /// Staff habilitó al inversionista a usar «Reservar» (además de status COMPLETED).
  staffReservationApprovedAt       DateTime?
  /// Id del usuario staff que aprobó (sin FK para no duplicar relación User↔CreditEvaluation).
  staffReservationApprovedByUserId String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([userId, status])
  @@index([floidCaseId])
  @@map("credit_evaluations")
}

model Reservation {
  id               String            @id @default(cuid())
  userId           String
  evaluationId     String?
  propertyId       String            // ID de la propiedad (puede venir de otro sistema)
  propertyName     String?           // Nombre/dirección para mostrar
  status           ReservationStatus @default(PENDING_PAYMENT)
  amount           Decimal           @db.Decimal(12, 2)
  currency         String            @default("CLP")

  // Pago
  paymentExternalId String?          // ID de Mercado Pago / Stripe
  paymentMethod     String?
  paymentUrl        String?          // URL de checkout generada
  paidAt            DateTime?

  // Metadata
  notes            String?           @db.Text
  metadata         Json?             // Datos extra del pago o propiedad
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expiresAt        DateTime?         // Cuándo expira la reserva si no se paga

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation CreditEvaluation? @relation(fields: [evaluationId], references: [id])

  @@index([userId, status])
  @@index([paymentExternalId])
  @@map("reservations")
}

// =============================================================================
// LEADS — Modelo existente (simplificado, ajustar a tu schema actual)
// =============================================================================

/// Single-use link: approved broker invites an investor; claim sets `User.sponsorBrokerUserId`.
model BrokerInvestorInvite {
  id               String                     @id @default(cuid())
  token            String                     @unique
  brokerUserId     String
  broker           User                       @relation("BrokerInvestorInviteBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  inviteeEmail     String?
  status           BrokerInvestorInviteStatus @default(PENDING)
  registeredUserId String?
  registeredUser   User?                      @relation("BrokerInvestorInviteRegistered", fields: [registeredUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                   @default(now())
  expiresAt        DateTime
  completedAt      DateTime?

  @@index([brokerUserId])
  @@map("broker_investor_invites")
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  source    String?  // De dónde vino el lead
  status    String?  // Estado del lead en tu CRM
  data      Json?    // Datos adicionales del lead
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con usuario del portal (cuando el lead se registra)
  user User?

  @@map("leads")
}

// =============================================================================
// INVENTARIO — Catálogo (staff + portal broker)
// =============================================================================

model Property {
  id               String         @id @default(cuid())
  title            String
  status           PropertyStatus @default(AVAILABLE)
  visibleToBrokers Boolean        @default(false)
  metadata         Json?
  /// Stable business key for CSV / manual inventory upserts (before or alongside Houm).
  inventoryCode    String?        @unique
  /// Stable id from Houm (or upstream catalog) for sync upserts; optional for manual-only rows.
  houmPropertyId   String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  catalogDraft PropertyCatalogDraft?

  @@index([status])
  @@map("properties")
}

/// Staging row (Houm sync or CSV import) until staff approves publication to `Property`.
model PropertyCatalogDraft {
  id                      String                       @id @default(cuid())
  source                  CatalogDraftSource
  houmPropertyId          String?                      @unique
  inventoryCode           String?                      @unique
  title                   String
  metadata                Json?
  status                  PropertyCatalogDraftStatus     @default(PENDING)
  /// CSV-only: target status when promoted to `Property` (Houm uses env default on approve).
  pendingPropertyStatus   PropertyStatus?
  pendingVisibleToBrokers Boolean?
  /// Set when approved: links to the official catalog row.
  propertyId              String?                      @unique
  property                Property?                    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  reviewedAt              DateTime?
  reviewedByUserId        String?
  rejectionReason         String?                      @db.Text
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  @@map("property_catalog_drafts")
}

// =============================================================================
// ENUMS
// =============================================================================

enum StaffRole {
  NONE
  SUPER_ADMIN
}

enum BrokerAccessStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BrokerInvestorInviteStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum CatalogDraftSource {
  HOUM
  CSV
}

enum PropertyCatalogDraftStatus {
  PENDING
  REJECTED
  APPROVED
}

enum EvaluationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ReservationStatus {
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  PAID
  CONFIRMED
  CANCELLED
  EXPIRED
  REFUNDED
}
