# =============================================================================
# MaxRent Portal — Variables de entorno
# =============================================================================
# Copia este archivo como .env.local y completa los valores
# =============================================================================

# --- Base ---
# Puerto por defecto del portal (evita choque con la app Next en la raíz del repo en :3000)
NEXTAUTH_URL=http://localhost:3002
# Generar con: openssl rand -base64 32 (obligatorio en producción)
NEXTAUTH_SECRET=

# --- Base de datos ---
DATABASE_URL=postgresql://user:password@localhost:5432/maxrent_portal
# Tras el primer deploy del schema: npx prisma migrate deploy (o npm run db:push en dev).
# Staff (panel /staff): en BD → UPDATE users SET "staffRole" = 'SUPER_ADMIN' WHERE email = '...';
# O lista de emails (coma/espacio) con acceso staff sin tocar BD (útil en dev):
# STAFF_SUPER_ADMIN_EMAILS=nk@houm.com,otro@empresa.cl
STAFF_SUPER_ADMIN_EMAILS=
# --- Beta cerrado ---
# Lista (coma o espacio) de emails autorizados para login durante el beta cerrado.
# Si está vacía o no definida, el portal opera SIN restricciones (modo abierto, default).
# Los emails de STAFF_SUPER_ADMIN_EMAILS pasan automáticamente, no hace falta duplicarlos acá.
# Ejemplo: PORTAL_BETA_ALLOWED_EMAILS=tester1@empresa.com,tester2@gmail.com
PORTAL_BETA_ALLOWED_EMAILS=

# --- Google OAuth ---
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client ID → Web Application
# Authorized redirect URIs: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (Magic Link emails) ---
# Registrarse en: https://resend.com
# Free tier: 3,000 emails/mes
RESEND_API_KEY=
EMAIL_FROM=MaxRent <noreply@maxrent.cl>

# --- Floid API (evaluación financiera / crediticia) ---
# Guía paso a paso: docs/FLOID_SETUP.md
# Docs API: https://docs.floid.io/ — REST, Bearer token, JSON.
#
# Sandbox (local / Vercel Preview): usar token y base URL que entregue el dashboard Floid para pruebas.
# Productivo: solo variables de producción en Vercel Production; cuidar cupos del contrato (ej. N consultas).
#
# Modo de operación:
#   - Si FLOID_WIDGET_URL está set y FLOID_USE_STUB!=true → usa widget productivo
#   - Si no → modo stub (simula payload, no llama a Floid)
#
# Widget URL del admin de Floid (admin.floid.app/<merchant>/widget/<widget_id>).
# El portal le concatena ?id=<RUT>&custom=<evaluationId> al abrir.
# FLOID_WIDGET_URL=https://admin.floid.app/houm_management/widget/<widget_id>
#
# (Legacy - flujo REST API directo, NO usado en widget. Se mantiene por compatibilidad
# con datos existentes; no es necesario set para el flujo widget productivo.)
FLOID_API_KEY=
FLOID_API_URL=https://api.floid.app
#
# true = siempre simular con payload demo; false = usar widget. Sin definir = stub si falta FLOID_WIDGET_URL.
# FLOID_USE_STUB=true
#
# Bearer secret para validar el POST de Floid al callback. En producción es OBLIGATORIO setear.
# Si Floid permite configurar el header en el widget admin, debe coincidir con este valor.
# FLOID_WEBHOOK_SECRET=

# --- Pasarela de pago ---
# Mercado Pago: https://www.mercadopago.cl/developers
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=

# Stripe (alternativa): https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Asesor / agenda (portal inversionista) ---
# Base URL del portal (sin barra final). Usada para armar enlaces de invitación broker→inversionista.
# En local, `npm run dev` usa el puerto 3002 por defecto.
# NEXT_PUBLIC_APP_URL=http://localhost:3002

# URL pública de reserva (CTA flotante + sidebar). Ej.: Google Calendar “Programación de citas”,
# Calendly, Cal.com, etc.
#
# Para que las citas queden en el calendario de nk@houm.com (u otra cuenta):
# 1) Iniciar sesión en https://calendar.google.com con esa cuenta.
# 2) Crear → “Programación de citas” (o “Appointment schedule”) → definir disponibilidad.
# 3) Copiar el enlace de reserva público y pegarlo aquí (sin comillas).
# 4) Reiniciar `npm run dev`. Las reuniones las recibe el calendario del usuario con el que creaste el enlace.
#
# Si dejás la variable vacía, el portal muestra un aviso para configurarla (desarrollo).
# NEXT_PUBLIC_ADVISOR_BOOKING_URL=https://calendar.app.google/...

# --- Houm catalog sync (M2M, server-only) ---
# Ver maxrent-portal/machine-to-machine-tokens.md (cache 23h, no loguear secretos).
# AUTH0_DOMAIN=houm.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_API_AUDIENCE=
# Base URL de la API Houm (sin barra final)
# HOUM_API_BASE_URL=https://api.example.com
# Path del listado de propiedades (GET, JSON array o { data|properties|items|results })
# HOUM_PROPERTIES_LIST_PATH=/admin/v2/properties
# Máximo de filas del listado a persistir por sync (si Houm devuelve más, se trunca y se avisa en la respuesta)
# HOUM_SYNC_MAX_ROWS=500
# GET de una propiedad por id; debe contener el placeholder {id} (URL-encoded). Requerido para sync «por IDs» en Staff.
# HOUM_PROPERTY_BY_ID_PATH=/admin/v2/properties/{id}
# Nuevas filas tras sync: por defecto NO publicadas. Poné "true" para publicarlas al crear.
# HOUM_SYNC_DEFAULT_VISIBLE_TO_BROKERS=true
